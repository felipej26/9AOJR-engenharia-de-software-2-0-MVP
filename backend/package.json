{
  "name": "financial-control-backend",
  "version": "1.0.0",
  "description": "MVP Backend - Controle financeiro pessoal",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:push": "prisma db push",
    "setup": "node scripts/init-db.js",
    "postinstall": "NODE_TLS_REJECT_UNAUTHORIZED=0 prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "zod": "^3.22.4",
    "@prisma/client": "^5.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "^5.7.0"
  }
}
